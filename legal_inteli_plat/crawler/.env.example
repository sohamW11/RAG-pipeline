# Environment overrides for the crawler service.
#
# Structural configuration lives in config/settings.yaml; only the
# deployment-varying values below are read from the environment (see
# crawler/config/settings.py::_apply_env_overrides).

# Path to the YAML configuration file.
CRAWLER_CONFIG_PATH=./config/settings.yaml

# Deployment identity / logging.
CRAWLER_ENV=local
CRAWLER_LOG_LEVEL=INFO

# Database. Local/dev uses async SQLite; production uses async PostgreSQL, e.g.
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/crawler
DATABASE_URL=sqlite+aiosqlite:///./crawler.db

# Object storage backend: local | s3 | minio
CRAWLER_STORAGE_BACKEND=local
CRAWLER_STORAGE_LOCAL_PATH=./storage-data

# Object-storage secrets (used when backend is s3 or minio).
STORAGE_BUCKET=legal-documents
STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Kafka event bus (disabled by default; a no-op publisher is used when off).
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis (optional; used for the distributed rate limiter when enabled).
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
